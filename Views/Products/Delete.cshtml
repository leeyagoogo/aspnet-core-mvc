@model E_commerce_PetShop.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<div class="container mt-4" style="font-family: sans-serif;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Delete Product</h3>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back to List</a>
    </div>

    <p class="text-muted mb-3">Are you sure you want to delete this product? This action cannot be undone.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Name</label>
                    <input type="text" class="form-control" value="@Model.Name" readonly style="background:#f8f9fa;" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Price</label>
                    <input type="text" class="form-control" value="@Model.Price.ToString("C")" readonly style="background:#f8f9fa;" />
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea class="form-control" rows="3" readonly style="background:#f8f9fa;">@Model.Description</textarea>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Stock</label>
                    <input type="text" class="form-control" value="@Model.Stock" readonly style="background:#f8f9fa;" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Created At</label>
                    <input type="text" class="form-control" value="@Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")" readonly style="background:#f8f9fa;" />
                </div>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>