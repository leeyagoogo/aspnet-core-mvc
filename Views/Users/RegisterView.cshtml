@model E_commerce_PetShop.Models.Users
@{
    ViewData["Title"] = "Register";
    Layout = "_LoginLayout";
}

<style>
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html, body {
        height: 100%;
        width: 100%;
        overflow: hidden;
        font-family: sans-serif;
    }

    .paw-page {
        display: flex;
        width: 100vw;
        height: 100vh;
    }

    .paw-left {
        flex: 1;
        background: #f2f2f2;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 64px;
        overflow-y: auto;
    }

    .paw-right {
        width: 45%;
        background: #F5A623 url('/pictures/bgmain.png') center/cover no-repeat;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center; /* center logo vertically */
        overflow: hidden;
    }

    .paw-form-wrap {
        width: 100%;
        max-width: 360px;
    }

        .paw-form-wrap h2 {
            font-size: 34px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 6px;
        }

        .paw-form-wrap p.subtitle {
            font-size: 14px;
            color: #666;
            margin-bottom: 24px;
        }

    .paw-lbl {
        display: block;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: #666;
        margin-bottom: 8px;
    }

    .paw-inp {
        width: 100%;
        height: 50px;
        background: #f2f2f2;
        border: 1.5px solid #ccc;
        border-radius: 6px;
        padding: 0 16px;
        font-size: 15px;
        color: #1a1a1a;
        margin-bottom: 20px;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .paw-inp:focus {
            border-color: #F5A623;
            box-shadow: 0 0 0 3px rgba(245,166,35,0.20);
        }

    .paw-pw-wrap {
        position: relative;
        margin-bottom: 20px;
    }

        .paw-pw-wrap .paw-inp {
            margin-bottom: 0;
            padding-right: 48px;
        }

    .paw-pw-toggle {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: #999;
        font-size: 17px;
        padding: 0;
        line-height: 1;
        transition: color 0.15s;
    }

        .paw-pw-toggle:hover {
            color: #F5A623;
        }

    .paw-btn {
        width: 100%;
        height: 54px;
        background: #1a1a1a;
        border: none;
        border-radius: 6px;
        color: #fff;
        font-size: 17px;
        font-weight: 600;
        cursor: pointer;
        letter-spacing: 0.3px;
        transition: background 0.18s, transform 0.1s;
    }

        .paw-btn:hover {
            background: #333;
        }

        .paw-btn:active {
            transform: scale(0.98);
        }

    .paw-new {
        font-size: 14px;
        color: #333;
        font-weight: 500;
        margin-top: 20px;
        text-align: center;
    }

        .paw-new a {
            color: #F5A623;
            font-weight: 700;
            text-decoration: none;
        }

            .paw-new a:hover {
                text-decoration: underline;
            }

    .paw-val-err {
        font-size: 12px;
        color: #d9534f;
        display: block;
        margin-top: -14px;
        margin-bottom: 12px;
    }
</style>

<div class="paw-page">
    <div class="paw-left">
        <div class="paw-form-wrap">
            <h2>Create your account</h2>
            <p class="subtitle">Fill in the details below to get started</p>

            <form asp-controller="Users" asp-action="Register" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2" style="font-size:13px;"></div>

                <label asp-for="Name" class="paw-lbl">Full Name</label>
                <input asp-for="Name" class="paw-inp" placeholder="Juan dela Cruz" />
                <span asp-validation-for="Name" class="paw-val-err"></span>

                <label asp-for="Email" class="paw-lbl">Email</label>
                <input asp-for="Email" class="paw-inp" placeholder="you@email.com" />
                <span asp-validation-for="Email" class="paw-val-err"></span>

                <label asp-for="Username" class="paw-lbl">Username</label>
                <input asp-for="Username" class="paw-inp" placeholder="juandc123" autocomplete="username" />
                <span asp-validation-for="Username" class="paw-val-err"></span>

                <label asp-for="Password" class="paw-lbl">Password</label>
                <div class="paw-pw-wrap">
                    <input asp-for="Password" class="paw-inp" type="password" id="pwField" autocomplete="new-password" />
                    <button type="button" class="paw-pw-toggle" id="pwToggle">&#128065;</button>
                </div>
                <span asp-validation-for="Password" class="paw-val-err"></span>

                <button type="submit" class="paw-btn">Create account</button>
            </form>

            <p class="paw-new">
                Already have an account? <a asp-controller="Users" asp-action="Login">Sign in</a>
            </p>
        </div>
    </div>
    <div class="paw-right">
        <img src="~/pictures/logo.png" alt="Pawtopia Logo"
             style="width:220px; object-fit:contain;" />
    </div>
</div>

@section Scripts {
    <script>
        const pwField = document.getElementById('pwField');
        const pwToggle = document.getElementById('pwToggle');
        pwToggle.addEventListener('click', function () {
            const isPassword = pwField.type === 'password';
            pwField.type = isPassword ? 'text' : 'password';
            pwToggle.innerHTML = isPassword ? '&#128064;' : '&#128065;';
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}