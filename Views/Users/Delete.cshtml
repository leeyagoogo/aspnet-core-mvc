@model E_commerce_PetShop.Models.Users
@{
    ViewData["Title"] = "Delete User";
}

<div class="container mt-4" style="font-family: sans-serif;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Delete User</h3>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back to List</a>
    </div>

    <p class="text-muted mb-3">Are you sure you want to delete this user? This action cannot be undone.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Name</label>
                    <input type="text" class="form-control" value="@Model.Name" readonly style="background:#f8f9fa;" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="text" class="form-control" value="@Model.Email" readonly style="background:#f8f9fa;" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Username</label>
                    <input type="text" class="form-control" value="@Model.Username" readonly style="background:#f8f9fa;" />
                </div>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
