@model E_commerce_PetShop.Models.Users
@{
    ViewData["Title"] = "User Details";
}

<div class="container mt-4" style="font-family: sans-serif;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">User Details</h3>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back to List</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Name</label>
                    <input type="text" class="form-control" value="@Model.Name" readonly style="background:#f8f9fa;" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="text" class="form-control" value="@Model.Email" readonly style="background:#f8f9fa;" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Username</label>
                    <input type="text" class="form-control" value="@Model.Username" readonly style="background:#f8f9fa;" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back to List</a>
            </div>
        </div>
    </div>
</div>
