<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E_commerce_PetShop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_commerce_PetShop.styles.css" asp-append-version="true" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
        }

        .navbar, .navbar a, .nav-link {
            font-family: 'Nunito', sans-serif; /* replace with your actual font name */
            font-size: 16px;
        }
    </style>
</head>
<body>

    <!--HEADER-->
    <header style="background:#F5A623; display:flex; align-items:center;
                   padding:0 32px; height:64px; position:sticky; top:0; z-index:100;
                   box-shadow: 0 2px 8px rgba(0,0,0,0.10);">

        <!-- Logo -->
        <div class="logo" style="flex-shrink:0;">
            <a asp-controller="Home" asp-action="Index">
                <img src="~/pictures/logotransparent.png" alt="PawTopia logo" style="height:44px;" />
            </a>
        </div>

        @{
            var hideNav = ViewData["HideNav"] as bool? ?? false;
        }

        @if (!hideNav)
        {
            <!-- Left spacer -->
            <div style="min-width:180px; flex-shrink:0;"></div>

            <!-- Nav links — centered -->
            <ul style="display:flex; align-items:center; gap:32px; list-style:none;
                     margin:0 auto; padding:0; flex:1; justify-content:center;
                     font-family: sans-serif;">
                <li>
                    <a asp-controller="Home" asp-action="Index"
                       style="color:#fff; font-weight:500; font-size:15px;
                            text-decoration:none; padding:6px 0;">Home</a>
                </li>
                <li>
                    <a asp-controller="Products" asp-action="Index"
                       style="color:#fff; font-weight:500; font-size:15px;
                            text-decoration:none; padding:6px 0;">Products</a>
                </li>
                <li>
                    <a asp-controller="Orders" asp-action="Index"
                       style="color:#fff; font-weight:500; font-size:15px;
                            text-decoration:none; padding:6px 0;">Orders</a>
                </li>
                <li>
                    <a asp-controller="Users" asp-action="Index"
                       style="color:#fff; font-weight:500; font-size:15px;
                            text-decoration:none; padding:6px 0;">Users</a>
                </li>
            </ul>
            <!-- User indicator — right -->
            @if (Context.Session.GetString("LoggedInUser") != null)
            {
                <div style="display:flex; align-items:center; gap:10px;
                                    flex-shrink:0; min-width:180px; justify-content:flex-end;">
                    <div style="width:34px; height:34px; border-radius:50%;
                                        background:#1a1a1a; display:flex; align-items:center;
                                        justify-content:center; font-weight:700; font-size:14px;
                                        color:#F5A623; flex-shrink:0;">
                        @Context.Session.GetString("LoggedInName")?.Substring(0, 1).ToUpper()
                    </div>
                    <span style="font-size:14px; font-weight:600; color:#fff;">
                        @Context.Session.GetString("LoggedInName")
                    </span>
                    <form asp-controller="Users" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                style="background:#1a1a1a; border:none; border-radius:6px;
                                               color:#F5A623; font-size:13px; font-weight:600;
                                               padding:6px 14px; cursor:pointer;">
                            Logout
                        </button>
                    </form>
                </div>
            }
        }
    </header>

    <!-- Optional full-width content (pages opt-in) -->
    @RenderSection("FullWidthHero", required: false)

    <!--MAIN CONTENT (constrained)-->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>