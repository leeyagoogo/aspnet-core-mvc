<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E_commerce_PetShop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_commerce_PetShop.styles.css" asp-append-version="true" />
</head>
<body>

    <!--HEADER-->
    <header>
        <div class="logo">
            <a asp-controller="Home" asp-action="Index">
                <img src="~/pictures/logotransparent.png" alt="PawTopia logo" />
            </a>
        </div>

        <div class="hamburger" id="hamburger">
            <img src="~/pictures/hamburger.png" alt="Menu" />
        </div>

        <nav id="nav">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Products" asp-action="Index">Products</a></li>
@*                 <li><a asp-controller="Home" asp-action="Index">About</a></li>
                <li><a asp-controller="Home" asp-action="Index">Contact</a></li> *@
                <li><a asp-controller="Users" asp-action="Index">Users</a></li>
                <li><a asp-controller="Users" asp-action="Login">Logout</a></li>
            </ul>
        </nav>

@*         <div class="icons">
            <div class="search-container">
                <img src="~/pictures/searchicon.png" id="searchIcon" />
                <input type="text" id="searchInput" placeholder="Search..." />
            </div>

            <div class="user-container">
                <img src="~/pictures/account.png" id="userIcon" alt="User" />
                <div class="login-dropdown" id="loginDropdown">
                    <form id="loginForm">
                        <input type="text" placeholder="Username" id="username" />
                        <input type="password" placeholder="Password" id="password" />
                        <button type="submit" class="login-btn">Login</button>
                    </form>
                </div>
            </div>

            <a asp-controller="Cart" asp-action="Index">
                <img src="~/pictures/carticon.png" alt="Cart" />
            </a>
        </div> *@
    </header>

    <!--MAIN CONTENT-->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
@* 
    <!--FOOTER-->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-left">
                <img src="~/pictures/logotransparent.png" alt="PawTopia logo" class="footer-logo" />
                <p>
                    If you have any questions, please <br />contact us at
                    <a href="mailto:pawtopia@example.com">pawtopia@example.com</a>
                </p>
                <div class="social-icons">
                    <a href="https://x.com" target="_blank">
                        <img src="~/pictures/twittard.png" alt="X" />
                    </a>
                    <a href="https://www.facebook.com" target="_blank">
                        <img src="~/pictures/facebook.png" alt="Facebook" />
                    </a>
                    <a href="https://www.instagram.com" target="_blank">
                        <img src="~/pictures/instagram.png" alt="Instagram" />
                    </a>
                    <a href="https://www.linkedin.com" target="_blank">
                        <img src="~/pictures/linkedin.png" alt="LinkedIn" />
                    </a>
                </div>
                <p>&copy; 2026 Pawtopia. All rights reserved.</p>
            </div>

            <div class="footer-right">
                <div class="footer-column">
                    <h3>Shop Now</h3>
                    <ul>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-category="dog">Dog</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-category="cat">Cat</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h3>Customer Service</h3>
                    <ul>
                        <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Contact Us</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer> *@

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
