@model E_commerce_PetShop.Models.Order
@{
    ViewData["Title"] = "Delete Order";
}

<div class="container mt-4" style="font-family: sans-serif;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Delete Order</h3>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back to List</a>
    </div>

    <p class="text-muted mb-3">Are you sure you want to delete this order? This action cannot be undone.</p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th>Ordered By</th>
                            <th style="width:90px;">Qty</th>
                            <th style="width:180px;">Ordered At</th>
                            <th style="width:120px;">Status</th>
                            <th style="width:120px;">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>@Model.Product?.Name</strong></td>
                            <td>@Model.OrderedByName</td>
                            <td>@Model.Quantity</td>
                            <td class="text-muted" style="font-size:0.9rem;">
                                @Model.OrderedAt.ToString("MMM dd, yyyy hh:mm tt")
                            </td>
                            <td>
                                <span class="badge @(Model.Status == E_commerce_PetShop.Models.OrderStatus.Completed  ? "bg-success" :
                                                                                           Model.Status == E_commerce_PetShop.Models.OrderStatus.Pending ? "bg-warning text-dark" :
                                                                                           Model.Status == E_commerce_PetShop.Models.OrderStatus.Cancelled ? "bg-danger" :
                                                                                           Model.Status == E_commerce_PetShop.Models.OrderStatus.Processing ? "bg-info text-dark" :
                                                                                           Model.Status == E_commerce_PetShop.Models.OrderStatus.Shipped ? "bg-primary" : "bg-secondary")">
                                    @Model.Status
                                </span>
                            </td>
                            <td><strong>@Model.Total.ToString("C")</strong></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="OrderId" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
